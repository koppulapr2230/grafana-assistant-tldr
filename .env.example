# Copy to .env (which is gitignored), fill in, then before launching claude:
#   set -a && source .env && set -a && claude
#
# Or put these exports in your shell rc so they're always present.

# Full URL of your Grafana Cloud stack.
GRAFANA_URL=https://<yourstack>.grafana.net

# Service account token.
# Create at: Administration > Users & Access > Service accounts > Add service account
# Role: Viewer is enough for read-only scanning. Use Editor if you want the skill
# to run datasource queries (it will).
GRAFANA_SERVICE_ACCOUNT_TOKEN=glsa_replace_me
